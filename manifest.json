{
    "manifest_version": 3,
    "name": "WOR Helper",
    "version": "1.2",
    "description": "Automation helper for the browser game World of Rest. Automates fishing, mining, combat, alchemy, map navigation, quests, and chat.",
    "permissions": [
        "storage",
        "activeTab",
        "tabs",
        "alarms"
    ],
    "host_permissions": [
        "http://185.212.47.8/wap/*",
        "https://wor.com.ua/wap/*",
        "*://worldofrest.com/wap/*"
    ],
    "background": {
        "service_worker": "Backend/background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "web_accessible_resources": [
        {
            "resources": [
                "Icons/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "content_scripts": [
        {
            "matches": [
                "*://wor.com.ua/wap/*",
                "*://wor.com.ua/wap/",
                "*://worldofrest.com/wap/*",
                "*://worldofrest.com/wap/",
                "http://185.212.47.8/wap/*",
                "http://185.212.47.8/wap/"
            ],
            "js": [
                "Common/moving-key.js",
                "Common/CommonHelper.js",
                "Chat/luxon.js",
                "Chat/Chat.js",
                "Common/process-common.js",
                "Common/process-commands.js",
                "Quest/WarlockQuestRunner.js",
                "Quest/process-warlock-runner.js"
            ]
        },
        {
            "matches": [
                "*://wor.com.ua/wap/lovit*",
                "*://wor.com.ua/wap/chat*",
                "*://wor.com.ua/wap/poisktrav*",
                "*://wor.com.ua/wap/kopat*",
                "*://worldofrest.com/wap/lovit*",
                "*://worldofrest.com/wap/chat*",
                "*://worldofrest.com/wap/poisktrav*",
                "*://worldofrest.com/wap/kopat*",
                "http://185.212.47.8/wap/lovit*",
                "http://185.212.47.8/wap/chat*",
                "http://185.212.47.8/wap/poisktrav*",
                "http://185.212.47.8/wap/kopat*"
            ],
            "js": [
                "Chat/process-chat.js"
            ]
        },
        {
            "matches": [
                "*://wor.com.ua/wap/game.php?show=5*",
                "*://worldofrest.com/wap/game.php?show=5*",
                "http://185.212.47.8/wap/game.php?show=5*"
            ],
            "js": [
                "Common/statistic-helper.js"
            ]
        },
        {
            "matches": [
                "*://wor.com.ua/wap/inventar.php*",
                "*://worldofrest.com/wap/inventar.php*",
                "http://185.212.47.8/wap/inventar.php*"
            ],
            "js": [
                "Common/inventory-helper.js"
            ]
        },
        {
            "matches": [
                "*://wor.com.ua/wap/poisktrav*",
                "*://wor.com.ua/wap/teritory*",
                "*://wor.com.ua/wap/main*",
                "*://wor.com.ua/wap/game*",
                "*://worldofrest.com/wap/poisktrav*",
                "*://worldofrest.com/wap/teritory*",
                "*://worldofrest.com/wap/main*",
                "*://worldofrest.com/wap/game*",
                "http://185.212.47.8/wap/poisktrav*",
                "http://185.212.47.8/wap/teritory*",
                "http://185.212.47.8/wap/main*",
                "http://185.212.47.8/wap/game*"
            ],
            "js": [
                "Chemistry/ChemistryClass.js",
                "Chemistry/process-chemistry.js"
            ]
        },
        {
            "matches": [
                "*://wor.com.ua/wap/kopat*",
                "*://wor.com.ua/wap/shaxtap*",
                "*://wor.com.ua/wap/shaxtal*",
                "*://wor.com.ua/wap/shaxtar*",
                "*://wor.com.ua/wap/teritory*",
                "*://wor.com.ua/wap/main*",
                "*://wor.com.ua/wap/game*",
                "*://worldofrest.com/wap/kopat*",
                "*://worldofrest.com/wap/shaxtap*",
                "*://worldofrest.com/wap/shaxtal*",
                "*://worldofrest.com/wap/shaxtar*",
                "*://worldofrest.com/wap/teritory*",
                "*://worldofrest.com/wap/main*",
                "*://worldofrest.com/wap/game*",
                "http://185.212.47.8/wap/kopat*",
                "http://185.212.47.8/wap/shaxtap*",
                "http://185.212.47.8/wap/shaxtal*",
                "http://185.212.47.8/wap/shaxtar*",
                "http://185.212.47.8/wap/teritory*",
                "http://185.212.47.8/wap/main*",
                "http://185.212.47.8/wap/game*"
            ],
            "js": [
                "Mining/Mining.js",
                "Mining/process-mining.js"
            ]
        },
        {
            "matches": [
                "*://wor.com.ua/wap/attackhouse*",
                "*://wor.com.ua/wap/boj*",
                "*://wor.com.ua/wap/wait*",
                "*://wor.com.ua/wap/logfull*",
                "*://worldofrest.com/wap/attackhouse*",
                "*://worldofrest.com/wap/boj*",
                "*://worldofrest.com/wap/wait*",
                "*://worldofrest.com/wap/logfull*",
                "http://185.212.47.8/wap/attackhouse*",
                "http://185.212.47.8/wap/boj*",
                "http://185.212.47.8/wap/wait*",
                "http://185.212.47.8/wap/logfull*"
            ],
            "js": [
                "Fight/Fight.js",
                "Fight/process-fight.js",
                "Fight/process-bandits.js"
            ]
        },
        {
            "matches": [
                "*://wor.com.ua/wap/lovit*",
                "*://wor.com.ua/wap/teritory*",
                "*://wor.com.ua/wap/main*",
                "*://wor.com.ua/wap/game*",
                "*://worldofrest.com/wap/lovit*",
                "*://worldofrest.com/wap/teritory*",
                "*://worldofrest.com/wap/main*",
                "*://worldofrest.com/wap/game*",
                "http://185.212.47.8/wap/lovit*",
                "http://185.212.47.8/wap/teritory*",
                "http://185.212.47.8/wap/main*",
                "http://185.212.47.8/wap/game*"
            ],
            "js": [
                "Fishing/FishingClass.js",
                "Fishing/fishing.js"
            ]
        },
        {
            "matches": [
                "*://wor.com.ua/wap/cap*",
                "*://wor.com.ua/wap/primanka*",
                "*://worldofrest.com/wap/cap*",
                "*://worldofrest.com/wap/primanka*",
                "http://185.212.47.8/wap/cap*",
                "http://185.212.47.8/wap/primanka*"
            ],
            "js": [
                "Captcha/Captcha.js",
                "Captcha/process-captcha.js"
            ]
        },
        {
            "matches": [
                "*://wor.com.ua/wap/teritory*",
                "*://worldofrest.com/wap/teritory*",
                "http://185.212.47.8/wap/teritory*"
            ],
            "js": [
                "Territory/Territory.js",
                "Territory/TaktAuto.js",
                "Territory/process-territory.js",
                "Territory/map-history.js"
            ]
        },
        {
            "matches": [
                "*://wor.com.ua/wap/",
                "*://wor.com.ua/wap/index.php*",
                "*://worldofrest.com/wap/",
                "*://worldofrest.com/wap/index.php*",
                "http://185.212.47.8/wap/",
                "http://185.212.47.8/wap/index.php*"
            ],
            "js": [
                "Login/process-login.js"
            ]
        },
        {
            "matches": [
                "*://wor.com.ua/wap/famerating*",
                "*://worldofrest.com/wap/famerating*",
                "http://185.212.47.8/wap/famerating*"
            ],
            "js": [
                "Rating/process-rating.js"
            ]
        },
        {
            "matches": [
                "*://wor.com.ua/wap/quest*",
                "*://worldofrest.com/wap/quest*",
                "http://185.212.47.8/wap/quest*"
            ],
            "js": [
                "Quest/WarlockQuestClass.js",
                "Quest/process-warlock-quest.js"
            ]
        }
    ]
}
