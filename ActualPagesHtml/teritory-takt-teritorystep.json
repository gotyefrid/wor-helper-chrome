    "belowHtml": "            <div class=\"contur\" style=\"font-size:11px\">\r\n                <span class=\"svet\">Тактическое сражение №110199</span><br/>\r\n                (Вы в команде №2)<br/>\r\n                <br/>\r\n                <span class=\"svet\">Вами нанесено урона:</span> <strong>0</strong><br/>\r\n                <span class=\"svet\">Вами захвачено баз:</span> <strong>239</strong><br/>\r\n                <br/>\r\n                <span class=\"svet\">Сражение выполнено на:</span>\r\n                <strong>45%</strong><br/>\r\n\t\t\t\t                <br/>\r\n                <span class=\"svet\">Состояние баз:</span><br/>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\tЛевая лесопилка:<span style=\"color:#CC00FF\">№2</span> (Гадкий Я)<br/>\r\n\t\t\t\t\tПравая лесопилка:<span style=\"color:#CC00FF\">№2</span> (_РоМ_)<br/>\r\n\t\t\t\t\tШахта кристаллов:<span style=\"color:#00FFFF\">№1</span> (QooQoo)<br/>\r\n\t\t\t\t\tЛевая ферма:<span style=\"color:#00FFFF\">№1</span> (Дональд Дак)<br/>\r\n\t\t\t\t\tПравая ферма:<span style=\"color:#CC00FF\">№2</span> (_РоМ_)<br/>\r\n\t\t\t\t\t\t\t\t                <br/>\r\n\t\t\t\t                    <span class=\"svet\">Команда №1:</span><br/>\r\n\t\t\t\t\t<a href=\"infouser.php?name=QooQoo&amp;uni=1772371601&amp;hash=6c47437\">QooQoo[30]</a>, <a href=\"infouser.php?name=Дональд Дак&amp;uni=1772371601&amp;hash=c16011c\">Дональд Дак[37]</a>, <a href=\"infouser.php?name=ZLO_&amp;uni=1772371601&amp;hash=04eb1de\">ZLO_[35]</a>, <a href=\"infouser.php?name=Gwath&amp;uni=1772371601&amp;hash=8307e6b\">Gwath[37]</a>, <a href=\"infouser.php?name=Mostik&amp;uni=1772371601&amp;hash=d8649dc\">Mostik[36]</a>, <a href=\"infouser.php?name=Vitrenko&amp;uni=1772371601&amp;hash=f22872a\">Vitrenko[34]</a>, <a href=\"infouser.php?name=Wite_Angel&amp;uni=1772371601&amp;hash=19e5814\">Wite_Angel[37]</a>                    <br/>\r\n\t\t\t\t                    <span class=\"svet\">Команда №2:</span><br/>\r\n\t\t\t\t\t<a href=\"infouser.php?name=_РоМ_&amp;uni=1772371601&amp;hash=1108e3f\">_РоМ_[35]</a>, <a href=\"infouser.php?name=WheeL&amp;uni=1772371601&amp;hash=bcbf4e5\">WheeL[26]</a>, <a href=\"infouser.php?name=ANTEL3000&amp;uni=1772371601&amp;hash=682bb19\">ANTEL3000[25]</a>, <a href=\"infouser.php?name=_BeN_&amp;uni=1772371601&amp;hash=5a7c22a\">_BeN_[36]</a>, <a href=\"infouser.php?name=Гадкий Я&amp;uni=1772371601&amp;hash=c703815\">Гадкий Я[38]</a>, <a href=\"infouser.php?name=LoseYourMind&amp;uni=1772371601&amp;hash=d566f97\">LoseYourMind[40]</a>                    <br/>\r\n\t\t\t\t            </div>\r\n\t\t\t<div class=\"cont\"><div class=\"menu_div\" align=\"left\"><ul><li><a   href=\"main.php?uni=1772371601&amp;hash=3b7616c\"><img src=\"icons/glavnoe_menyu_128.png\" border=\"0\" style=\"vertical-align:middle; margin-right:3px; width:32px; height:32px\" alt=\"\" />  Главное меню</a></li><li><a   href=\"game.php?uni=1772371601&amp;hash=51b7192\"><img src=\"icons/vash_personazh_m1_128.png\" border=\"0\" style=\"vertical-align:middle; margin-right:3px; width:32px; height:32px\" alt=\"\" />  Ваш персонаж</a></li><li><a   href=\"inventar.php?uni=1772371601&amp;hash=44b7972\"><img src=\"icons/inventar_128.png\" border=\"0\" style=\"vertical-align:middle; margin-right:3px; width:32px; height:32px\" alt=\"\" />  Инвентарь</a></li><li><a   href=\"journal.php?uni=1772371601&amp;hash=ae45dff\"><img src=\"icons/journal_128.png\" border=\"0\" style=\"vertical-align:middle; margin-right:3px; width:32px; height:32px\" alt=\"\" />  Журнал событий</a></li></ul></div></div>",
